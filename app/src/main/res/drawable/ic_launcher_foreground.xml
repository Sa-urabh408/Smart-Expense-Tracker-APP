<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- =============================== -->
    <!-- OUTER SHIELD - Metallic Rim     -->
    <!-- =============================== -->
    <path
        android:pathData="M54,4 L98,21 L98,60 Q98,92 54,105 Q10,92 10,60 L10,21 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="10"
                android:startY="4"
                android:endX="98"
                android:endY="105">
                <item android:offset="0.0"  android:color="#FFB8CCE0"/>
                <item android:offset="0.35" android:color="#FFE2F0FA"/>
                <item android:offset="0.65" android:color="#FF7A8DB5"/>
                <item android:offset="1.0"  android:color="#FF3A4A90"/>
            </gradient>
        </aapt:attr>
    </path>

    <!-- Outer shield dark body -->
    <path
        android:pathData="M54,7 L95,23 L95,60 Q95,89 54,101 Q13,89 13,60 L13,23 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="13"
                android:startY="7"
                android:endX="95"
                android:endY="101">
                <item android:offset="0.0" android:color="#FF252E4A"/>
                <item android:offset="1.0" android:color="#FF151C32"/>
            </gradient>
        </aapt:attr>
    </path>

    <!-- =============================== -->
    <!-- INNER SHIELD - Purple Blue      -->
    <!-- =============================== -->
    <path
        android:pathData="M54,15 L87,29 L87,59 Q87,81 54,92 Q21,81 21,59 L21,29 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="21"
                android:startY="15"
                android:endX="87"
                android:endY="92">
                <item android:offset="0.0"  android:color="#FF362875"/>
                <item android:offset="0.45" android:color="#FF1E2C5C"/>
                <item android:offset="1.0"  android:color="#FF141E40"/>
            </gradient>
        </aapt:attr>
    </path>

    <!-- Inner shield rim stroke -->
    <path
        android:pathData="M54,14 L88,28 L88,59 Q88,82 54,93 Q20,82 20,59 L20,28 Z"
        android:fillColor="#00000000"
        android:strokeColor="#6878BE"
        android:strokeWidth="1.4"/>

    <!-- =============================== -->
    <!-- WALLET / LEDGER BOOK            -->
    <!-- =============================== -->
    <path
        android:pathData="M33,33 Q33,30 36,30 L72,30 Q75,30 75,33 L75,65 Q75,68 72,68 L36,68 Q33,68 33,65 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="33"
                android:startY="30"
                android:endX="75"
                android:endY="68">
                <item android:offset="0.0" android:color="#FF2A3255"/>
                <item android:offset="1.0" android:color="#FF1A2040"/>
            </gradient>
        </aapt:attr>
    </path>

    <!-- Wallet spine -->
    <path
        android:pathData="M33,30 L40,30 L40,68 L33,68 Q33,68 33,65 L33,33 Q33,30 33,30 Z"
        android:fillColor="#181E38"/>

    <!-- Wallet page lines -->
    <path
        android:pathData="M44,41 L70,41"
        android:fillColor="#00000000"
        android:strokeColor="#3A4568"
        android:strokeWidth="1.5"
        android:strokeLineCap="round"/>
    <path
        android:pathData="M44,48 L70,48"
        android:fillColor="#00000000"
        android:strokeColor="#3A4568"
        android:strokeWidth="1.5"
        android:strokeLineCap="round"/>
    <path
        android:pathData="M44,55 L60,55"
        android:fillColor="#00000000"
        android:strokeColor="#3A4568"
        android:strokeWidth="1.5"
        android:strokeLineCap="round"/>

    <!-- Wallet clasp outer -->
    <path
        android:pathData="M75,49 m-5,0 a5,5 0 1,0 10,0 a5,5 0 1,0 -10,0"
        android:fillColor="#222A48"
        android:strokeColor="#485580"
        android:strokeWidth="1.3"/>

    <!-- Wallet clasp inner -->
    <path
        android:pathData="M75,49 m-2.5,0 a2.5,2.5 0 1,0 5,0 a2.5,2.5 0 1,0 -5,0"
        android:fillColor="#181E38"
        android:strokeColor="#5868A0"
        android:strokeWidth="0.9"/>

    <!-- =============================== -->
    <!-- TEAL ARROW - Up Right           -->
    <!-- =============================== -->
    <path
        android:pathData="M36,76 L70,28"
        android:fillColor="#00000000"
        android:strokeWidth="5"
        android:strokeLineCap="round">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:type="linear"
                android:startX="36"
                android:startY="76"
                android:endX="70"
                android:endY="28">
                <item android:offset="0.0" android:color="#FF30B89A"/>
                <item android:offset="1.0" android:color="#FF88EED8"/>
            </gradient>
        </aapt:attr>
    </path>
    <!-- Teal arrowhead -->
    <path
        android:pathData="M70,28 L59,33 L65,42 Z"
        android:fillColor="#88EED8"/>

    <!-- =============================== -->
    <!-- TEAL ARROW - Up Left            -->
    <!-- =============================== -->
    <path
        android:pathData="M36,76 L24,38"
        android:fillColor="#00000000"
        android:strokeWidth="4"
        android:strokeLineCap="round">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:type="linear"
                android:startX="36"
                android:startY="76"
                android:endX="24"
                android:endY="38">
                <item android:offset="0.0" android:color="#FF30B89A"/>
                <item android:offset="1.0" android:color="#FF68D8C0"/>
            </gradient>
        </aapt:attr>
    </path>
    <!-- Teal arrowhead up-left -->
    <path
        android:pathData="M24,38 L22,50 L33,45 Z"
        android:fillColor="#68D8C0"/>

    <!-- =============================== -->
    <!-- PURPLE ARROW - Down Left        -->
    <!-- =============================== -->
    <path
        android:pathData="M70,28 L42,86"
        android:fillColor="#00000000"
        android:strokeWidth="4.5"
        android:strokeLineCap="round">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:type="linear"
                android:startX="70"
                android:startY="28"
                android:endX="42"
                android:endY="86">
                <item android:offset="0.0" android:color="#FF5548BB"/>
                <item android:offset="1.0" android:color="#FF9080E0"/>
            </gradient>
        </aapt:attr>
    </path>
    <!-- Purple arrowhead down-left -->
    <path
        android:pathData="M42,86 L49,74 L38,75 Z"
        android:fillColor="#9080E0"/>

    <!-- =============================== -->
    <!-- PURPLE ARROW - Down Right       -->
    <!-- =============================== -->
    <path
        android:pathData="M35,42 L76,86"
        android:fillColor="#00000000"
        android:strokeWidth="4"
        android:strokeLineCap="round">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:type="linear"
                android:startX="35"
                android:startY="42"
                android:endX="76"
                android:endY="86">
                <item android:offset="0.0" android:color="#FF5548BB"/>
                <item android:offset="1.0" android:color="#FF9080E0"/>
            </gradient>
        </aapt:attr>
    </path>
    <!-- Purple arrowhead down-right -->
    <path
        android:pathData="M76,86 L67,76 L72,65 Z"
        android:fillColor="#9080E0"/>

    <!-- =============================== -->
    <!-- GLOBE / COMPASS CENTER          -->
    <!-- =============================== -->
    <!-- Globe outer glow ring -->
    <path
        android:pathData="M54,52 m-14,0 a14,14 0 1,0 28,0 a14,14 0 1,0 -28,0"
        android:fillColor="#00000000"
        android:strokeColor="#4060A8"
        android:strokeWidth="2.5"/>

    <!-- Globe body -->
    <path
        android:pathData="M54,52 m-13,0 a13,13 0 1,0 26,0 a13,13 0 1,0 -26,0">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="41"
                android:startY="39"
                android:endX="67"
                android:endY="65">
                <item android:offset="0.0" android:color="#FF1E2C58"/>
                <item android:offset="1.0" android:color="#FF121A38"/>
            </gradient>
        </aapt:attr>
    </path>

    <!-- Globe rim highlight -->
    <path
        android:pathData="M54,52 m-13,0 a13,13 0 1,0 26,0 a13,13 0 1,0 -26,0"
        android:fillColor="#00000000"
        android:strokeColor="#5878C0"
        android:strokeWidth="1"/>

    <!-- Globe longitude oval -->
    <path
        android:pathData="M54,39 Q60,46 60,52 Q60,58 54,65 Q48,58 48,52 Q48,46 54,39 Z"
        android:fillColor="#00000000"
        android:strokeColor="#3858A0"
        android:strokeWidth="0.9"/>

    <!-- Globe latitude lines -->
    <path
        android:pathData="M41,52 L67,52"
        android:fillColor="#00000000"
        android:strokeColor="#3858A0"
        android:strokeWidth="0.9"/>
    <path
        android:pathData="M43,46 L65,46"
        android:fillColor="#00000000"
        android:strokeColor="#3858A0"
        android:strokeWidth="0.7"/>
    <path
        android:pathData="M43,58 L65,58"
        android:fillColor="#00000000"
        android:strokeColor="#3858A0"
        android:strokeWidth="0.7"/>

    <!-- Compass cross -->
    <path
        android:pathData="M54,40 L54,64"
        android:fillColor="#00000000"
        android:strokeColor="#90C0D8"
        android:strokeWidth="1.2"/>
    <path
        android:pathData="M41,52 L67,52"
        android:fillColor="#00000000"
        android:strokeColor="#90C0D8"
        android:strokeWidth="1.2"/>

    <!-- Compass cardinal dots -->
    <path android:pathData="M54,41 m-1.8,0 a1.8,1.8 0 1,0 3.6,0 a1.8,1.8 0 1,0 -3.6,0" android:fillColor="#70C8E0"/>
    <path android:pathData="M54,63 m-1.8,0 a1.8,1.8 0 1,0 3.6,0 a1.8,1.8 0 1,0 -3.6,0" android:fillColor="#7068C0"/>
    <path android:pathData="M42,52 m-1.8,0 a1.8,1.8 0 1,0 3.6,0 a1.8,1.8 0 1,0 -3.6,0" android:fillColor="#70C8E0"/>
    <path android:pathData="M66,52 m-1.8,0 a1.8,1.8 0 1,0 3.6,0 a1.8,1.8 0 1,0 -3.6,0" android:fillColor="#7068C0"/>

    <!-- Globe center dot -->
    <path
        android:pathData="M54,52 m-3,0 a3,3 0 1,0 6,0 a3,3 0 1,0 -6,0"
        android:fillColor="#4070B8"
        android:strokeColor="#88B0D8"
        android:strokeWidth="0.8"/>

    <!-- =============================== -->
    <!-- SHIELD TOP HIGHLIGHT            -->
    <!-- =============================== -->
    <path
        android:pathData="M54,4 L98,21 L95,23 L54,7 L13,23 L10,21 Z"
        android:fillColor="#28D8F0FF"/>

</vector>