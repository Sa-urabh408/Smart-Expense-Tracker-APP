<?xml version="1.0" encoding="utf-8"?>
<!--
  Subscription list item card
  Shows: emoji icon + name + category + price/cycle + urgency badge
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:background="@drawable/bg_sub_card"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="14dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?android:attr/selectableItemBackground">

    <!-- Emoji icon box -->
    <TextView
        android:id="@+id/tvSubEmoji"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:background="@drawable/bg_icon_box"
        android:gravity="center"
        android:text="📦"
        android:textSize="20sp" />

    <!-- Name + Category + Badge -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvSubName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="Netflix"
            android:textColor="@color/textPrimary"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvSubCategory"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Entertainment"
            android:textColor="@color/textSecondary"
            android:textSize="12sp" />

        <!-- Urgency badge -->
        <TextView
            android:id="@+id/tvSubBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:background="@drawable/bg_badge_red"
            android:paddingHorizontal="10dp"
            android:paddingVertical="3dp"
            android:text="⚡ 3 din baaki"
            android:textColor="@color/subRedAlert"
            android:textSize="11sp"
            android:textStyle="bold"
            android:visibility="gone" />
    </LinearLayout>

    <!-- Price + Cycle -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="end"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvSubPrice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="₹649"
            android:textColor="@color/textPrimary"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvSubCycle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:text="/month"
            android:textColor="@color/textSecondary"
            android:textSize="11sp" />
    </LinearLayout>

</LinearLayout>
