<?xml version="1.0" encoding="utf-8"?>
<!--
  Subscription Strip — single-line card for dashboard
  Shows: icon + title + subtitle + monthly total + due badge + arrow
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="10dp"
    android:background="@drawable/bg_subscription_strip"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingHorizontal="14dp"
    android:paddingVertical="14dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?android:attr/selectableItemBackground">

    <!-- Left: Gradient icon box -->
    <TextView
        android:layout_width="38dp"
        android:layout_height="38dp"
        android:background="@drawable/bg_icon_box"
        android:gravity="center"
        android:text="🔄"
        android:textSize="16sp" />

    <!-- Title + Subtitle -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/subscriptions"
            android:textColor="@color/textPrimary"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvStripActive"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="0 active plans"
            android:textColor="@color/textSecondary"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- Monthly total -->
    <TextView
        android:id="@+id/tvStripMonthly"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="8dp"
        android:text="₹0/mo"
        android:textColor="@color/subPurpleLight"
        android:textSize="15sp"
        android:textStyle="bold" />

    <!-- Due-soon badge (visibility toggled) -->
    <TextView
        android:id="@+id/tvStripDue"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_due_badge"
        android:paddingHorizontal="7dp"
        android:paddingVertical="3dp"
        android:text="⚡0"
        android:textColor="@android:color/white"
        android:textSize="11sp"
        android:textStyle="bold"
        android:visibility="gone" />

    <!-- Arrow -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:text="›"
        android:textColor="@color/textSecondary"
        android:textSize="20sp" />

</LinearLayout>
