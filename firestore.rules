rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Transactions ────────────────────────────────────────────────
    // Users can only read/write their own transactions
    match /transactions/{docId} {
      allow read, write: if request.auth != null
                         && request.auth.uid == resource.data.userId;
      allow create:      if request.auth != null
                         && request.auth.uid == request.resource.data.userId;
    }

    // ── Users ───────────────────────────────────────────────────────
    // Any authenticated user can read user profiles (needed for member lookup by email)
    // Users can only write their own profile
    match /users/{userId} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Groups ──────────────────────────────────────────────────────
    // Only members of a group can read or modify it
    match /groups/{groupId} {
      allow read, update, delete:
        if request.auth != null
           && request.auth.uid in resource.data.members;

      // Creator must include themselves in the members array
      allow create:
        if request.auth != null
           && request.auth.uid in request.resource.data.members;

      // ── Group Expenses (subcollection) ───────────────────────────
      // Only group members can read/write expenses
      match /expenses/{expenseId} {
        allow read, write:
          if request.auth != null
             && request.auth.uid in
                get(/databases/$(database)/documents/groups/$(groupId)).data.members;
      }
    }
  }
}
